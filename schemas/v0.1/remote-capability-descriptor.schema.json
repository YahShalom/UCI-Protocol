{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Remote Capability Descriptor",
  "description": "Describes a capability hosted on a remote UCI node.",
  "type": "object",
  "properties": {
    "capability_key": {
      "type": "string",
      "description": "The unique identifier for the capability."
    },
    "remote_node_url": {
      "type": "string",
      "format": "uri",
      "description": "The base URL of the remote UCI node."
    },
    "discovery_url": {
      "type": "string",
      "format": "uri",
      "description": "The URL to the discovery document for this capability."
    },
    "version": {
      "type": "string",
      "description": "The version of the capability."
    },
    "publisher": {
      "type": "object",
      "properties": {
        "org_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      },
      "required": ["org_id", "name"]
    },
    "trust": {
      "type": "object",
      "properties": {
        "verification_status": {
          "type": "string",
          "enum": ["verified", "unverified", "pending"]
        },
        "evidence_profile": {
          "type": "string"
        }
      },
      "required": ["verification_status"]
    }
  },
  "required": [
    "capability_key",
    "remote_node_url",
    "discovery_url",
    "version",
    "publisher",
    "trust"
  ]
}
